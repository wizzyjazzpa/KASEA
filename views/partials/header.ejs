  <style>
   
    .card {
      background-color: #111427;
      border-radius: 12px;
      border: none;
      padding: 20px;
      color: #fff;
    }
    .highlight-text {
      color: #ff4d4d;
      font-weight: bold;
    }
    .price-box {
      font-size: 1.2rem;
      font-weight: bold;
      color: #ddd;
      background: #1a1d33;
      padding: 8px 14px;
      border-radius: 8px;
      display: inline-block;
    }
    .progress {
      background-color: #222;
      height: 10px;
      border-radius: 8px;
    }
    .progress-bar {
      background-color: #00e6b8;
    }
    .payment-method {
      background: #1a1d33;
      border-radius: 10px;
      padding: 15px;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .payment-method:hover {
      background: #2c3052;
    }
    .number-box {
      font-size: 1.5rem;
      font-weight: bold;
      color: #00e6b8;
    }
    .section-title {
      font-size: 0.9rem;
      text-transform: uppercase;
      margin-bottom: 8px;
      color: #bbb;
    }
    </style>
</head>
