<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>WalletConnect with Web3Modal</title>

  <!-- Web3.js -->
  <script src="https://cdn.jsdelivr.net/npm/web3@1.10.0/dist/web3.min.js"></script>

  <!-- WalletConnect Provider -->
  <script src="https://cdn.jsdelivr.net/npm/@walletconnect/web3-provider@1.8.0/dist/umd/index.min.js"></script>

  <!-- Web3Modal -->
  <script src="https://cdn.jsdelivr.net/npm/web3modal@1.9.12/dist/index.js"></script>
</head>
<body>
  <h2>WalletConnect Demo</h2>

  <button id="connectBtn">Connect Wallet</button>
  <p id="walletAddress">No wallet connected</p>

  <script>
    // Provider options
    const providerOptions = {
      walletconnect: {
        package: window.WalletConnectProvider, // 👈 no `.default`
        options: {
          rpc: {
            1: "https://rpc.ankr.com/eth",   // Ethereum Mainnet (public RPC)
            137: "https://rpc.ankr.com/polygon" // Polygon Mainnet
          }
          // Or: infuraId: "YOUR_INFURA_ID"
        }
      }
    };

    // Create Web3Modal
    const web3Modal = new window.Web3Modal.default({
      cacheProvider: false,
      providerOptions
    });

    let web3;

    async function connectWallet() {
      try {
        const provider = await web3Modal.connect();
        web3 = new Web3(provider);

        const accounts = await web3.eth.getAccounts();
        document.getElementById("walletAddress").innerText = "Connected: " + accounts[0];

        // Send to server
        fetch("/save-wallet", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ address: accounts[0], wallet: "walletconnect" })
        });

      } catch (err) {
        console.error("Connection failed:", err);
      }
    }

    document.getElementById("connectBtn").addEventListener("click", connectWallet);
  </script>
</body>
</html>
