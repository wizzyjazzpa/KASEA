<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>EJS + Vue + Phantom Example</title>
  <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
</head>
<body>
  <div id="app">
    <h2>{{ title }}</h2>

    <p v-if="!connected">
      No wallet connected
    </p>

    <p v-else>
      ✅ Connected: {{ address }}
    </p>

    <button @click="connectWallet" :disabled="connecting">
      {{ connecting ? "Connecting..." : "Connect Phantom" }}
    </button>
  </div>

  <script>
    const { createApp } = Vue;

    createApp({
      data() {
        return {
          title: "Vue + EJS + Phantom Demo",
          connected: false,
          address: "",
          connecting: false
        };
      },
      methods: {
        async connectWallet() {
          try {
            if (!window.solana || !window.solana.isPhantom) {
              alert("Phantom wallet not found. Please install Phantom.");
              return;
            }

            this.connecting = true;

            const resp = await window.solana.connect();
            this.address = resp.publicKey.toString();
            this.connected = true;
            this.connecting = false;

            // Send wallet info to Node server
            fetch("/save-wallet", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                wallet: this.address,
                walletName: "Phantom",
                chain: "Solana"
              })
            });
          } catch (err) {
            console.error("Connection failed:", err);
            this.connecting = false;
          }
        }
      },
      mounted() {
        // Auto-check if already connected
        if (window.solana && window.solana.isPhantom) {
          window.solana.connect({ onlyIfTrusted: true })
            .then(resp => {
              this.address = resp.publicKey.toString();
              this.connected = true;
            })
            .catch(() => {
              console.log("No Phantom session yet");
            });

          // Listen for account change
          window.solana.on("accountChanged", (pubKey) => {
            if (pubKey) {
              this.address = pubKey.toString();
              this.connected = true;
            } else {
              this.connected = false;
              this.address = "";
            }
          });
        }
      }
    }).mount("#app");
  </script>
</body>
</html>
