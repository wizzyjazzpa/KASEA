<!DOCTYPE html>
<html>
<head>
  <title>Thirdweb + EJS</title>
  <!-- Thirdweb browser SDK -->
  <script src="https://unpkg.com/thirdweb@latest/dist/browser/thirdweb.production.min.js"></script>
</head>
<body>
  <h1>Thirdweb + EJS Wallet Connect</h1>

  <button id="connect">Connect Wallet</button>
  <p id="status">Not connected</p>

  <script>
    async function connectWallet() {
      try {
        const client = new thirdweb.createThirdwebClient({
          clientId: "YOUR_CLIENT_ID" // optional
        });

        const wallet = await thirdweb.connect({
          client,
          wallets: [
            thirdweb.wallets.metamask(),
            thirdweb.wallets.coinbaseWallet(),
            thirdweb.wallets.walletConnect()
          ]
        });

        const address = wallet.getAccount().address;
        document.getElementById("status").innerText = "Connected: " + address;

        console.log("Wallet:", wallet);
      } catch (err) {
        console.error(err);
        document.getElementById("status").innerText = "Connection failed";
      }
    }

    document.getElementById("connect").addEventListener("click", connectWallet);
  </script>
</body>
</html>
